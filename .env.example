# ============================================================
# NyayaLex.AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Groq API — free tier at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# CourtListener — free token at https://www.courtlistener.com/sign-in/
# Without token: 100 req/day (very slow)
# With free token: 5,000 req/day (~6 days for all 28k SCOTUS cases)
COURTLISTENER_TOKEN=your_courtlistener_token_here

# HuggingFace — free token at https://huggingface.co/settings/tokens
# Needed to upload ChromaDB to HF Hub Dataset repo (scripts/upload_to_hub.py)
# and to download it on HuggingFace Spaces startup
HF_TOKEN=your_huggingface_token_here
HF_DATASET_REPO=your_hf_username/nyayalex-vectorstore

# ChromaDB
CHROMA_HOST=http://localhost:8001

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
